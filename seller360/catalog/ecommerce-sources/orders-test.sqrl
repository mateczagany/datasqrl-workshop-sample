-- Order Data Tables for Test Environment
--
-- Uses filesystem connector with file monitoring for streaming test data.
-- Requires configuring `script.config.ecommerce-test-data` config variable to either `dev` (for local testing) or `qa` in package.json.


/** Stream of customer orders with nested line items referencing products and sellers.
  Order events are produced by the online ordering system. */
CREATE TABLE OrderEvents (
    order_id STRING NOT NULL,
    customer_id STRING NOT NULL, -- FK to masterdata Customers
    order_purchase_timestamp TIMESTAMP(3) NOT NULL,
    order_estimated_delivery_date TIMESTAMP(3),
    items ARRAY<ROW<
        order_item_id INT,
        product_id STRING,
        seller_id STRING, -- FK to masterdata Products
        shipping_limit_date TIMESTAMP(3), -- time by which seller must ship order
        price DOUBLE,
        freight_value DOUBLE
    >> NOT NULL,
    WATERMARK FOR order_purchase_timestamp AS order_purchase_timestamp - INTERVAL '0.001' SECOND
) WITH (
    'connector' = 'filesystem',
    'path' = '${DATA_PATH}/ecommerce-orders-{{ecommerce-test-data}}.jsonl',
    'format' = 'json',
    'json.timestamp-format.standard' = 'SQL',
    'source.monitor-interval' = '10 min'
);

/** Stream of payment transactions.
    Payment transactions happen within 30 days of an order (i.e. transaction_approved_at < order_purchase_timestamp + INTERVAL 30 DAYS) since orders are closed for non-payment within that interval. */
CREATE TABLE PaymentEvents (
    order_id STRING NOT NULL,
    payment_sequential INT NOT NULL, -- when the payment is split this captures the sequence number
    payment_type STRING, -- credit_card, boleto, voucher, etc
    payment_installments INT, -- >1 if payment is made in multiple installments
    payment_value DOUBLE,
    transaction_approved_at TIMESTAMP(3) NOT NULL,
    WATERMARK FOR transaction_approved_at AS transaction_approved_at - INTERVAL '0.001' SECOND
) WITH (
    'connector' = 'filesystem',
    'path' = '${DATA_PATH}/ecommerce-payments-{{ecommerce-test-data}}.jsonl',
    'format' = 'json',
    'json.timestamp-format.standard' = 'SQL',
    'source.monitor-interval' = '10 min'
);

/** Stream of order fulfillment events (shipped, delivered).
  Fulfillment events happen within 60 days of the order being placed (i.e. timestamp < order_purchase_timestamp + INTERVAL 60 DAYS) since orders are closed or considered lost after that time. */
CREATE TABLE OrderFulfillmentEvents (
    order_id STRING NOT NULL,
    event_type STRING NOT NULL, -- one of: shipped, delivered
    `timestamp` TIMESTAMP(3) NOT NULL,
    WATERMARK FOR `timestamp` AS `timestamp` - INTERVAL '0.001' SECOND
) WITH (
    'connector' = 'filesystem',
    'path' = '${DATA_PATH}/ecommerce-orderfulfillment-{{ecommerce-test-data}}.jsonl',
    'format' = 'json',
    'json.timestamp-format.standard' = 'SQL',
    'source.monitor-interval' = '10 min'
);

/** Stream of customer reviews for their orders.
  Review events happen within 90 days of order placement (i.e. review_answer_timestamp < order_purchase_timestamp + INTERVAL 90 DAYS) since feedback surveys are only accessible within that interval. */
CREATE TABLE ReviewEvents (
    review_id STRING NOT NULL,
    order_id STRING NOT NULL,
    review_score INT,
    review_comment_title STRING,
    review_comment_message STRING,
    review_creation_date TIMESTAMP(3), -- when the feedback survey was sent out
    review_answer_timestamp TIMESTAMP(3) NOT NULL,
    WATERMARK FOR review_answer_timestamp AS review_answer_timestamp - INTERVAL '0.001' SECOND
) WITH (
    'connector' = 'filesystem',
    'path' = '${DATA_PATH}/ecommerce-reviews-{{ecommerce-test-data}}.csv',
    'format' = 'csv',
    'csv.ignore-parse-errors' = 'true',
    'csv.allow-comments' = 'true',
    'source.monitor-interval' = '10 min'
);
