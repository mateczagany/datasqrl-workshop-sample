{
  "version": "1",
  "enabled-engines": ["flink", "postgres", "kafka", "vertx"],
  "script": {
    "main": "seller360.sqrl",
    "config": {
      "environment": "prod"
    }
  },
  "engines": {
    "flink": {
      "config": {
        "execution.runtime-mode": "STREAMING",
        "table.exec.source.idle-timeout": "1 s"
      }
    },
    "vertx": {
      "authKind": ["JWT"],
      "config": {
        "jwtAuth": {
          "pubSecKeys": [
            {
              "algorithm": "HS256",
              "buffer": "${SELLER360_RBAC_JWT_SECRET_BASE64}"
            }
          ],
          "jwtOptions": {
            "issuer": "seller360-rbac",
            "audience": ["seller360-api"],
            "expiresInSeconds": "3600",
            "leeway": "60"
          }
        }
      }
    }
  },
  "compiler": {
    "predicate-pushdown-rules": "LIMITED_RULES",
    "api": {
      "protocols": ["GRAPHQL", "REST", "MCP"],
      "endpoints": "FULL",
      "add-prefix": true,
      "default-limit": 20
    }
  }
}
