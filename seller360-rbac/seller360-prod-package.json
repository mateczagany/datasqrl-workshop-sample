{
  "version": "1",
  "enabled-engines": ["flink", "postgres", "kafka", "vertx"],
  "script": {
    "main": "seller360.sqrl",
    "config": {
      "environment": "prod"
    }
  },
  "engines": {
    "flink": {
      "config": {
        "execution.runtime-mode": "STREAMING",
        "table.exec.source.idle-timeout": "1 s"
      }
    }
  },
  "compiler": {
    "predicate-pushdown-rules": "LIMITED_RULES",
    "api": {
      "protocols": ["GRAPHQL", "REST", "MCP"],
      "endpoints": "FULL",
      "add-prefix": true,
      "default-limit": 20
    }
  }
}
